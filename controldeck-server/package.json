{
  "name": "controldeck-server",
  "version": "1.0.0",
  "license": "CC-BY-NC-SA-4.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "ws": "^8.18.0"
  },
  "build": {
    "appId": "com.controlsdeck.server",
    "productName": "ControlsDeck",
    "files": [
      "**/*",
      "!node_modules/.cache/**/*",
      "!dist/**/*",
      "!electron.log",
      "!plugins/**/*",
      "!build/**/*",
      {
        "from": "../shared",
        "to": "shared",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": true
    },
    "extraResources": [
      {
        "from": "plugins",
        "to": "plugins",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true
  }
}
